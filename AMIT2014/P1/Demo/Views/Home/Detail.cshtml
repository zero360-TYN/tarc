@model Student
@{
    ViewBag.Title = "Home | Detail";
    var s = Model;
}
<p>
    <img src="/Images/favicon.png">
</p>

<table class="table detail">
    <tr>
        <th>Id</th>
        <td>@s.Id</td>
    </tr>
    <tr>
        <th>Name</th>
        <td>@s.Name</td>
    </tr>
    <tr>
        <th>Gender</th>
        <td>@(s.Gender == "F" ? "Female": "Male")</td>
    </tr>
    <tr>
        <th>Program</th>
        <td>@s.Program.Id - @s.Program.Name</td>
    </tr>
</table>

<p>
    <button data-get="/">Index</button>
</p>
